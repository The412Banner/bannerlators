<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#ff102a66" />
            <stroke android:width="1.0dip" android:color="#ff1d6dff" />
            <corners android:radius="8.0dip" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#ff070a10" />
            <stroke android:width="1.0dip" android:color="#ff0055ff" />
            <corners android:radius="8.0dip" />
        </shape>
    </item>
</selector>
